# Copy to .env and fill in. Never commit the real .env.

# sqlite is fine for local dev outside Docker. docker-compose.yml defaults to
# Postgres instead.
DATABASE_URL=sqlite:////data/exchanger.db

# AML-18 compliance-service client. Register this service as a developer
# project via AML-18's POST /developer/signup (see compliance-service repo),
# then paste the issued key here.
AML18_BASE_URL=http://localhost:8300
AML18_API_KEY=
AML18_REQUEST_TIMEOUT_SECONDS=10
WALLET_OWNERSHIP_THRESHOLD_EUR=1000

# 0x Swap API v2 (https://api.0x.org). ZEROX_API_KEY is REQUIRED -- 0x
# retired the unauthenticated v1 API; get a free key at 0x.org/pricing,
# every quote call fails with 401 without one. Also required as of v2:
# a `taker` address is sent when the hot wallet is configured (omitted
# for a pre-wallet-setup quote preview, see app/liquidity/factory.py).
ZEROX_API_BASE_URL=https://api.0x.org
ZEROX_API_KEY=
ZEROX_REQUEST_TIMEOUT_SECONDS=10
SWAP_QUOTE_TTL_SECONDS=30

# EVM RPC provider. Alchemy recommended (free tier, Sepolia testnet support,
# no vendor lock-in since this service only ever speaks plain JSON-RPC) --
# see RUNBOOK.md for account setup. Infura works too (same URL shape); a
# self-hosted node works but needs its own sync/ops, overkill for a demo.
# NEVER commit an API key or the hot wallet's private key.
# EVM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/<API_KEY>
EVM_RPC_URL=
EVM_CHAIN_ID=1
# Sepolia testnet RPC, used by chain_listeners in dev/demo runs before any
# mainnet funds are involved (see RUNBOOK.md step-by-step).
# EVM_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/<API_KEY>
EVM_SEPOLIA_RPC_URL=
EVM_MIN_CONFIRMATIONS=12
EVM_LISTENER_POLL_INTERVAL_SECONDS=15

# BTC chain listener (public Blockstream Esplora API by default; point at
# your own node for anything beyond a demo).
BTC_ESPLORA_API_BASE_URL=https://blockstream.info/api
BTC_NETWORK=mainnet
BTC_MIN_CONFIRMATIONS=1
BTC_LISTENER_POLL_INTERVAL_SECONDS=30

# Dev-only hot wallet key storage (see app/custody/key_management.py).
# TODO(production): replace with HSM/MPC custody.
# HOT_WALLET_KEYS_FILE points at a local Fernet-encrypted JSON file;
# HOT_WALLET_KEYS_FERNET_KEY is the encryption key for that file
# (generate with `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"`).
HOT_WALLET_KEYS_FILE=./tmp/data/hot_wallet_keys.enc.json
HOT_WALLET_KEYS_FERNET_KEY=

# Admin UI (single operator, not public).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
SECRET_KEY=
