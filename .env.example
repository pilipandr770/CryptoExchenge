# Copy to .env (same directory as docker-compose.yml). docker-compose reads
# this automatically for the ${VAR:-default} interpolation in
# docker-compose.yml. exchanger-service/.env (copy from
# exchanger-service/.env.example) is loaded on top of these inside the
# container -- keep secrets there, not here, if you'd rather not have them
# in this root file.

POSTGRES_USER=exchanger
POSTGRES_PASSWORD=exchanger
POSTGRES_DB=exchanger

# Where AML+18's compliance-service is reachable from inside this stack's
# containers. If you're running AML+18's own docker-compose stack on the
# same machine, host.docker.internal:8300 (the default) reaches its
# published port. See RUNBOOK.md.
AML18_BASE_URL=http://host.docker.internal:8300
AML18_API_KEY=

# REQUIRED -- 0x's v2 API rejects every call without a key. Get a free one
# at 0x.org/pricing.
ZEROX_API_BASE_URL=https://api.0x.org
ZEROX_API_KEY=

EVM_RPC_URL=
EVM_CHAIN_ID=1
EVM_SEPOLIA_RPC_URL=
EVM_MIN_CONFIRMATIONS=12

BTC_ESPLORA_API_BASE_URL=https://blockstream.info/api
BTC_NETWORK=mainnet
BTC_MIN_CONFIRMATIONS=1

HOT_WALLET_KEYS_FERNET_KEY=

ADMIN_USERNAME=admin
ADMIN_PASSWORD=
SECRET_KEY=
